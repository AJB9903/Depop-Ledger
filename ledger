      </div>
 
      {/* ══════════════════════════════════════
          OVERVIEW
      ══════════════════════════════════════ */}
      {tab==="overview" && (
        <div style={{ padding:"28px 28px 48px", display:"flex", flexDirection:"column", gap:18 }}>
 
          {/* Timeframe toggle */}
          <div style={{ display:"flex", gap:6, alignItems:"center" }}>
            {["weekly","monthly","yearly"].map(f => (
              <Pill key={f} active={tf===f} onClick={()=>setTf(f)}>
                {f[0].toUpperCase()+f.slice(1)}
              </Pill>
            ))}
            <span style={{ fontFamily:mono, fontSize:9, color:C.dim, marginLeft:8 }}>
              {filtered.length} sales &nbsp;·&nbsp; {periodDays}d window
            </span>
          </div>
 
          {/* ── Hero Three ── */}
          <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit, minmax(210px,1fr))", gap:12 }}>
 
            {/* Revenue */}
            <Glass style={{ padding:"24px 26px" }}>
              <Lbl style={{ marginBottom:14 }}>Total Revenue</Lbl>
              <div style={{ fontFamily:mono, fontSize:40, fontWeight:700, color:C.amber, lineHeight:1, letterSpacing:"-0.03em" }}>
                {fm(totalRev)}
              </div>
              <div style={{ fontFamily:mono, fontSize:10, color:C.dim, marginTop:10 }}>
                {filtered.length} items &nbsp;·&nbsp; avg {fm(totalRev/(filtered.length||1))} / sale
              </div>
            </Glass>
 
            {/* Gross Profit */}
            <Glass style={{ padding:"24px 26px" }}>
              <Lbl style={{ marginBottom:14 }}>Gross Profit</Lbl>
              <div style={{ fontFamily:mono, fontSize:40, fontWeight:700, color:grossP>=0?C.sage:C.red, lineHeight:1, letterSpacing:"-0.03em" }}>
                {fm(grossP)}
              </div>
              <div style={{ fontFamily:mono, fontSize:10, color:C.dim, marginTop:10 }}>
                {pct(grossP, totalRev)} margin
              </div>
              {missingCogs>0 && (
                <div style={{ marginTop:12, background:"rgba(255,191,0,0.08)", borderRadius:C.rs, padding:"6px 10px", fontFamily:mono, fontSize:9, color:C.amber }}>
                  ⚠ {missingCogs} items missing COGS
                </div>
              )}
            </Glass>
 
            {/* Sales Velocity */}
            <Glass style={{ padding:"24px 26px" }}>
              <Lbl style={{ marginBottom:14 }}>Sales Velocity</Lbl>
              <div style={{ fontFamily:mono, fontSize:40, fontWeight:700, color:C.pri, lineHeight:1, letterSpacing:"-0.03em" }}>
                {velocity.toFixed(2)}
              </div>
              <div style={{ fontFamily:mono, fontSize:10, color:C.dim, marginTop:10 }}>
                items / day &nbsp;·&nbsp; {(velocity*7).toFixed(1)} / week
              </div>
            </Glass>
 
          </div>
 
          {/* ── Sparkline + Needs Action ── */}
          <div style={{ display:"grid", gridTemplateColumns:"1fr 260px", gap:12 }}>
 
            <Glass style={{ padding:"22px 24px" }}>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
                <Lbl>Revenue Flow &nbsp;·&nbsp; {tf}</Lbl>
                <div style={{ fontFamily:mono, fontSize:10, color:C.sage }}>
                  peak {fm(Math.max(...sparkData,0))}
                </div>
              </div>
              <Sparkline data={sparkData} height={82} />
              <div style={{ display:"flex", justifyContent:"space-between", fontFamily:mono, fontSize:8, color:C.dim, marginTop:6 }}>
                <span>start</span><span>end</span>
              </div>
            </Glass>
 
            <Glass style={{ padding:"22px 24px", display:"flex", flexDirection:"column" }}>
              <Lbl style={{ marginBottom:12 }}>Needs Action</Lbl>
              <div style={{ fontFamily:mono, fontSize:52, fontWeight:700, color:needsAction>0?C.red:C.sage, lineHeight:1 }}>
                {needsAction}
              </div>
              <div style={{ display:"flex", flexDirection:"column", gap:9, marginTop:18, flex:1 }}>
                {[
                  ["Missing ship label",    missingLabels,  missingLabels>0?C.red:C.dim],
                  ["Unmatched PS labels",   orphans.length, orphans.length>0?C.red:C.dim],
                  ["Missing COGS entry",    missingCogs,    missingCogs>0?C.amber:C.dim],
                ].map(([lbl, val, col]) => (
                  <div key={lbl} style={{ display:"flex", justifyContent:"space-between", fontFamily:mono, fontSize:10 }}>
                    <span style={{ color:C.mut }}>{lbl}</span>
                    <span style={{ color:col, fontWeight:700 }}>{val}</span>
                  </div>
                ))}
              </div>
              <button onClick={()=>setTab("issues")} style={{ marginTop:16, background:"rgba(255,107,107,0.1)", border:"none", borderRadius:C.rs, padding:"8px 0", color:C.red, fontFamily:mono, fontSize:9, cursor:"pointer", letterSpacing:"0.08em" }}>
                VIEW ISSUES →
              </button>
            </Glass>
 
          </div>
 
          {/* ── Sourcing Intelligence ── */}
          {info && (
            <div>
              <Lbl style={{ marginBottom:12 }}>Sourcing Intelligence</Lbl>
              <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit, minmax(190px,1fr))", gap:12 }}>
 
                {[
                  { tag:"Top Brand · Revenue",    name:info.topBrand.name, rev:info.topBrand.revenue, roi:info.topBrand.roi, of:pct(info.topBrand.revenue,info.totalRev), accent:C.amber },
                  { tag:"Brand ROI Leader",        name:info.roiBrand.name, rev:info.roiBrand.revenue, roi:info.roiBrand.roi, of:`${info.roiBrand.count} sale${info.roiBrand.count!==1?"s":""}`, accent:C.sage },
                  { tag:"Top Category · Revenue",  name:info.topCat.name,   rev:info.topCat.revenue,   roi:info.topCat.roi,   of:pct(info.topCat.revenue,info.totalRev),   accent:C.amber },
                  { tag:"Category ROI Leader",     name:info.roiCat.name,   rev:info.roiCat.revenue,   roi:info.roiCat.roi,   of:`${info.roiCat.count} sale${info.roiCat.count!==1?"s":""}`,   accent:C.sage },
                ].map(card => (
                  <Glass key={card.tag} style={{ padding:"20px 22px", borderRadius:C.ri }}>
                    <Lbl style={{ marginBottom:10 }}>{card.tag}</Lbl>
                    <div style={{ fontFamily:sans, fontSize:16, fontWeight:700, color:C.pri, marginBottom:14, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>
                      {card.name}
                    </div>
                    <div style={{ display:"flex", gap:18 }}>
                      <div>
                        <Lbl style={{ fontSize:8, marginBottom:3 }}>{card.of}</Lbl>
                        <div style={{ fontFamily:mono, fontSize:15, fontWeight:700, color:card.accent }}>{fm(card.rev)}</div>
                      </div>
                      <div>
                        <Lbl style={{ fontSize:8, marginBottom:3 }}>Margin</Lbl>
                        <div style={{ fontFamily:mono, fontSize:15, fontWeight:700, color:C.sage }}>{pct(card.rev*card.roi, card.rev)}</div>
                      </div>
                    </div>
                  </Glass>
                ))}
 
              </div>
            </div>
          )}
 
          {/* ── Fee strip ── */}
          <Glass style={{ padding:"18px 24px" }}>
            <div style={{ display:"flex", gap:28, flexWrap:"wrap" }}>
              {[
                ["Platform Fees",   fm(totalFees),            pct(totalFees,totalRev)+" of rev"],
                ["Shipping Spend",  fm(totalShip),            pct(totalShip,totalRev)+" of rev"],
                ["Total Taken",     fm(totalFees+totalShip),  pct(totalFees+totalShip,totalRev)+" of rev"],
                ["COGS Entered",    fm(totalCogs),            `${withNet.filter(t=>t.cogs!==null).length} / ${withNet.length} items`],
              ].map(([lbl,val,sub]) => (
                <div key={lbl}>
                  <Lbl style={{ marginBottom:4 }}>{lbl}</Lbl>
                  <div style={{ fontFamily:mono, fontSize:15, fontWeight:700, color:C.mut }}>{val}</div>
                  <div style={{ fontFamily:mono, fontSize:9, color:C.dim, marginTop:2 }}>{sub}</div>
                </div>
              ))}
            </div>
          </Glass>
 
        </div>
      )}
 
      {/* ══════════════════════════════════════
          LEDGER
      ══════════════════════════════════════ */}
      {tab==="ledger" && (
        <div style={{ padding:"20px 28px" }}>
          <div style={{ display:"flex", gap:6, marginBottom:16, justifyContent:"space-between", flexWrap:"wrap", alignItems:"center" }}>
            <div style={{ display:"flex", gap:6 }}>
              {[["all","All"],["orphaned","Orphaned"],["losses","Losses"]].map(([k,l])=>(
                <Pill key={k} active={lFilter===k} onClick={()=>setLFilter(k)}>{l}</Pill>
              ))}
            </div>
            <div style={{ fontFamily:mono, fontSize:9, color:C.dim }}>{ledgerRows.length} records</div>
          </div>
 
          <div style={{ overflowX:"auto", borderRadius:C.r, background:"rgba(0,0,0,0.22)" }}>
            <table style={{ width:"100%", borderCollapse:"collapse", fontSize:11 }}>
              <thead>
                <tr>
                  <TH col="saleDate"    ch="Date" />
                  <TH col="buyerName"   ch="Buyer" />
                  <TH col="brand"       ch="Brand" />
                  <TH col="category"    ch="Cat." />
                  <TH col="itemName"    ch="Item" />
                  <TH col="salePrice"   ch="Sale" />
                  <TH col="totalFees"   ch="Fees" />
                  <TH col="labelCost"   ch="Ship" />
                  <TH col="grossProfit" ch="Gross" />
                  <th style={{ padding:"10px 14px", fontFamily:mono, fontSize:9, letterSpacing:"0.1em", textTransform:"uppercase", color:C.amber, background:"rgba(0,0,0,0.35)", textAlign:"left", whiteSpace:"nowrap", borderBottom:`1px solid ${C.border}` }}>COGS</th>
                  <TH col="netProfit"   ch="Net" />
                </tr>
              </thead>
              <tbody>
                {ledgerRows.map(t => {
                  const loss = t.grossProfit < 0;
                  return (
                    <tr key={t.transactionId} className="rtr" style={{ borderBottom:`1px solid rgba(255,255,255,0.04)` }}>
                      <td style={{ padding:"10px 14px", fontFamily:mono, fontSize:9, color:C.dim, whiteSpace:"nowrap" }}>{t.saleDate}</td>
                      <td style={{ padding:"10px 14px", whiteSpace:"nowrap" }}>
                        <div style={{ fontSize:11, color:C.pri }}>{t.buyerName}</div>
                        <div style={{ fontFamily:mono, fontSize:8, color:C.dim }}>@{t.buyerUsername}</div>
                      </td>
                      <td style={{ padding:"10px 14px", fontSize:10, color:C.mut, whiteSpace:"nowrap" }}>{t.brand}</td>
                      <td style={{ padding:"10px 14px" }}>
                        <span style={{ fontFamily:mono, fontSize:8, background:"rgba(157,193,131,0.1)", color:C.sage, borderRadius:4, padding:"2px 7px", whiteSpace:"nowrap" }}>
                          {t.category}
                        </span>
                      </td>
                      <td style={{ padding:"10px 14px", maxWidth:200, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap", fontSize:10, color:C.mut }} title={t.itemName}>{t.itemName}</td>
                      <td style={{ padding:"10px 14px", fontFamily:mono, fontSize:10, color:C.pri, textAlign:"right", whiteSpace:"nowrap" }}>{fm(t.salePrice)}</td>
                      <td style={{ padding:"10px 14px", fontFamily:mono, fontSize:10, color:"rgba(255,107,107,0.75)", textAlign:"right", whiteSpace:"nowrap" }}>-{fm(t.totalFees)}</td>
                      <td style={{ padding:"10px 14px", textAlign:"right", whiteSpace:"nowrap" }}>
                        {t.isOrphaned
                          ? <span style={{ fontFamily:mono, fontSize:8, color:C.amber }}>⚠ NO LABEL</span>
                          : <span style={{ fontFamily:mono, fontSize:10, color:"rgba(255,107,107,0.75)" }}>-{fm(t.labelCost)}</span>}
                      </td>
                      <td style={{ padding:"10px 14px", fontFamily:mono, fontSize:10, fontWeight:700, color:loss?C.red:C.sage, textAlign:"right", whiteSpace:"nowrap" }}>
                        {loss?"-":""}{fm(t.grossProfit)}
                      </td>
                      <td style={{ padding:"6px 10px" }}>
                        <input type="number" step="0.01" min="0" placeholder="0.00"
                          value={cogsMap[t.transactionId]??""}
                          onChange={e=>setCogsMap(m=>({...m,[t.transactionId]:e.target.value}))}
                          style={{ width:64, background:"rgba(255,191,0,0.07)", border:`1px solid rgba(255,191,0,0.18)`, borderRadius:6, color:C.amber, fontFamily:mono, fontSize:10, padding:"5px 7px" }}
                        />
                      </td>
                      <td style={{ padding:"10px 14px", fontFamily:mono, fontSize:10, fontWeight:700, textAlign:"right", whiteSpace:"nowrap",
                        color:t.netProfit===null?C.dim:t.netProfit<0?C.red:C.sage }}>
                        {t.netProfit!==null?`${t.netProfit<0?"-":""}${fm(t.netProfit)}`:"—"}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
              <tfoot>
                <tr style={{ borderTop:`2px solid ${C.border}` }}>
                  <td colSpan={5} style={{ padding:"12px 14px", fontFamily:mono, fontSize:8, color:C.dim }}>TOTALS · {ledgerRows.length}</td>
                  <td style={{ padding:"12px 14px", fontFamily:mono, fontSize:10, fontWeight:700, color:C.pri, textAlign:"right" }}>{fm(ledgerRows.reduce((s,t)=>s+t.salePrice,0))}</td>
                  <td style={{ padding:"12px 14px", fontFamily:mono, fontSize:10, fontWeight:700, color:C.red, textAlign:"right" }}>-{fm(ledgerRows.reduce((s,t)=>s+t.totalFees,0))}</td>
                  <td style={{ padding:"12px 14px", fontFamily:mono, fontSize:10, fontWeight:700, color:C.red, textAlign:"right" }}>-{fm(ledgerRows.reduce((s,t)=>s+t.labelCost,0))}</td>
                  <td style={{ padding:"12px 14px", fontFamily:mono, fontSize:10, fontWeight:700, color:C.sage, textAlign:"right" }}>{fm(ledgerRows.reduce((s,t)=>s+t.grossProfit,0))}</td>
                  <td />
                  <td style={{ padding:"12px 14px", fontFamily:mono, fontSize:10, fontWeight:700, color:C.sage, textAlign:"right" }}>
                    {ledgerRows.some(t=>t.netProfit!==null)?fm(ledgerRows.reduce((s,t)=>s+(t.netProfit??t.grossProfit),0)):"—"}
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
          <div style={{ marginTop:10, fontFamily:mono, fontSize:8, color:C.dim }}>
            GROSS = Sale − Depop Payments Fee − Boosting Fee − Pirate Ship Label &nbsp;·&nbsp; NET = Gross − COGS
          </div>
        </div>
      )}
 
      {/* ══════════════════════════════════════
          ISSUES
      ══════════════════════════════════════ */}
      {tab==="issues" && (
        <div style={{ padding:"24px 28px", display:"flex", flexDirection:"column", gap:22 }}>
 
          <div>
            <Lbl style={{ color:C.red, marginBottom:12 }}>⚠ Depop sales without a Pirate Ship label</Lbl>
            <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
              {withNet.filter(t=>t.isOrphaned).map(t => (
                <Glass key={t.transactionId} style={{ padding:"16px 20px", borderRadius:C.ri, display:"flex", justifyContent:"space-between", flexWrap:"wrap", gap:12 }}>
                  <div>
                    <div style={{ fontWeight:600, fontSize:13 }}>{t.buyerName}</div>
                    <div style={{ fontFamily:mono, fontSize:9, color:C.dim, marginTop:3 }}>{t.saleDate} · {t.itemName.slice(0,55)}…</div>
                  </div>
                  <div style={{ textAlign:"right" }}>
                    <div style={{ fontFamily:mono, fontSize:13, fontWeight:700, color:C.amber }}>{fm(t.salePrice)}</div>
                    <div style={{ fontFamily:mono, fontSize:8, color:C.red, marginTop:2 }}>Shipping unknown — gross profit overstated</div>
                  </div>
                </Glass>
              ))}
              {withNet.filter(t=>t.isOrphaned).length===0 && (
                <div style={{ fontFamily:mono, fontSize:10, color:C.dim }}>All sales matched ✓</div>
              )}
            </div>
          </div>
 
          <div>
            <Lbl style={{ color:C.amber, marginBottom:12 }}>⚠ Pirate Ship labels without a Depop sale</Lbl>
            <div style={{ display:"flex", flexDirection:"column", gap:8 }}>
              {orphans.map((l,i) => (
                <Glass key={i} style={{ padding:"16px 20px", borderRadius:C.ri, display:"flex", justifyContent:"space-between", flexWrap:"wrap", gap:12 }}>
                  <div>
                    <div style={{ fontWeight:600, fontSize:13 }}>{l.buyerName}</div>
                    <div style={{ fontFamily:mono, fontSize:9, color:C.dim, marginTop:3 }}>{l.date}</div>
                  </div>
                  <div style={{ textAlign:"right" }}>
                    <div style={{ fontFamily:mono, fontSize:13, fontWeight:700, color:C.red }}>-{fm(l.labelCost)}</div>
                    <div style={{ fontFamily:mono, fontSize:8, color:C.dim, marginTop:2 }}>May be Poshmark, Mercari, or direct</div>
                  </div>
                </Glass>
              ))}
            </div>
          </div>
 
        </div>
      )}
 
      {/* ══════════════════════════════════════
          JSON
      ══════════════════════════════════════ */}
      {tab==="json" && (
        <div style={{ padding:"20px 28px" }}>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:14 }}>
            <Lbl>{txns.length} records · master ledger</Lbl>
            <button onClick={exportJson} style={{ background:C.sage, color:"#0d1a08", border:"none", borderRadius:C.rs, padding:"7px 16px", fontFamily:mono, fontSize:9, fontWeight:700, cursor:"pointer", letterSpacing:"0.06em" }}>
              DOWNLOAD .JSON
            </button>
          </div>
          <pre style={{ background:"rgba(0,0,0,0.45)", backdropFilter:"blur(24px)", WebkitBackdropFilter:"blur(24px)", borderRadius:C.ri, padding:20, fontSize:9, color:"rgba(157,193,131,0.8)", overflowX:"auto", maxHeight:600, overflowY:"auto", lineHeight:1.65, fontFamily:mono }}>
            {JSON.stringify({transactions:withNet,orphanedLabels:orphans},null,2)}
          </pre>
        </div>
      )}
 
    </div>
  );
}
