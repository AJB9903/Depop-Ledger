function parseMoney(val) {
  if (val === null || val === undefined) return 0;
  const s = String(val).replace(/[$,]/g, "").trim();
  if (["", "-", '="-"', '"-"'].includes(s)) return 0;
  const n = parseFloat(s);
  return isNaN(n) ? 0 : n;
}
 
function simpleHash(str) {
  let hash = 5381;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) + hash) ^ str.charCodeAt(i);
    hash = hash >>> 0;
  }
  return hash.toString(16).padStart(8, "0").toUpperCase() +
         str.length.toString(16).padStart(4, "0").toUpperCase();
}
 
function generateTxnId(row) {
  if (row["Transaction ID"] && row["Transaction ID"].toString().trim() !== "")
    return { id: row["Transaction ID"].toString().trim(), type: "depop" };
  const raw = `${row["Date of sale"]}_${row["Name"]}_${row["Item price"]}`;
  return { id: "HASH_" + simpleHash(raw), type: "hash" };
}
 
function normalizeName(name) { return String(name).toLowerCase().replace(/[^a-z]/g, ""); }
 
function nameSimilarity(a, b) {
  const na = normalizeName(a), nb = normalizeName(b);
  if (!na || !nb) return 0;
  if (na === nb) return 1;
  const shorter = na.length <= nb.length ? na : nb;
  const longer  = na.length <= nb.length ? nb : na;
  let matches = 0;
  for (const ch of shorter) if (longer.includes(ch)) matches++;
  return matches / longer.length;
}
 
function parsePirateShipRows(rows) {
  const labels = [];
  for (const row of rows) {
    if (row["Type"] !== "Label") continue;
    const desc = String(row["Description"] || "");
    const name = desc.split(":")[0].trim();
    const cost = Math.abs(parseMoney(row["Total"]));
    const dateStr = String(row["Date"] || "").replace(/ EDT$/, "").replace(/ EST$/, "").trim();
    const date = new Date(dateStr);
    if (!isNaN(date.getTime()) && name) labels.push({ name, date, cost });
  }
  return labels;
}
 
export function mergeAndDeduplicate(depopRows, pirateShipRows, existingIds = new Set()) {
  const labels = parsePirateShipRows(pirateShipRows);
  const usedLabelIndices = new Set();
  const transactions = [], orphanedLabels = [];
  const seenIds = new Set(existingIds);
 
  for (const row of depopRows) {
    const { id: txnId, type: idType } = generateTxnId(row);
    if (seenIds.has(txnId)) continue; // dedup gate
    seenIds.add(txnId);
 
    const saleDate      = new Date(row["Date of sale"]);
    const buyerName     = String(row["Name"] || "").trim();
    const itemPrice     = parseMoney(row["Item price"]);
    const depopFee      = parseMoney(row["Depop fee"]);
    const depopPayFee   = parseMoney(row["Depop Payments fee"]);
    const boostingFee   = parseMoney(row["Boosting fee"]);
    const buyerShipping = parseMoney(row["Buyer shipping cost"]);
    const totalFees     = depopFee + depopPayFee + boostingFee;
 
    let bestMatch = null, bestScore = 0, bestIdx = -1;
    for (let i = 0; i < labels.length; i++) {
      if (usedLabelIndices.has(i)) continue;
      const label = labels[i];
      const daysDiff = Math.abs((label.date.getTime() - saleDate.getTime()) / 86400000);
      if (daysDiff > 5) continue;
      const score = nameSimilarity(buyerName, label.name);
      if (score > bestScore && score > 0.7) { bestScore = score; bestMatch = label; bestIdx = i; }
    }
 
    let labelCost = 0, shippingDate = null;
    if (bestMatch) {
      usedLabelIndices.add(bestIdx);
      labelCost = bestMatch.cost;
      shippingDate = bestMatch.date.toISOString().split("T")[0];
    }
 
    const grossProfit = Math.round((itemPrice - totalFees - labelCost) * 100) / 100;
    transactions.push({
      transactionId: txnId, idType,
      saleDate: row["Date of sale"],
      itemName: String(row["Description"] || "").slice(0, 80).trim(),
      brand: String(row["Brand"] || "").trim(),
      category: String(row["Category"] || "Other").trim(),
      buyerUsername: String(row["Buyer"] || "").trim(),
      buyerName, postCode: String(row["Post Code"] || "").trim(),
      salePrice: itemPrice, buyerShipping, depopFee,
      depopPaymentsFee: depopPayFee, boostingFee,
      totalFees: Math.round(totalFees * 100) / 100,
      labelCost, shippingDate,
      matchConfidence: bestMatch ? Math.round(bestScore * 100) / 100 : null,
      grossProfit, cogs: null, netProfit: null,
      isOrphaned: !bestMatch,
      orphanReason: !bestMatch ? "No matching shipping label found" : null,
    });
  }
 
  for (let i = 0; i < labels.length; i++) {
    if (!usedLabelIndices.has(i)) {
      const label = labels[i];
      orphanedLabels.push({
        type: "orphaned_label", buyerName: label.name,
        date: label.date.toISOString().split("T")[0],
        labelCost: label.cost, note: "Pirate Ship label with no matching Depop sale",
      });
    }
  }
  return { transactions, orphanedLabels };
}
 
export function useLedgerParser() {
  const parseCsv = useCallback((file) => new Promise((resolve, reject) => {
    if (typeof Papa === "undefined") { reject(new Error("PapaParse not loaded.")); return; }
    Papa.parse(file, { header: true, skipEmptyLines: true, complete: r => resolve(r.data), error: reject });
  }), []);
 
  const parseXlsx = useCallback((file) => new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        if (typeof XLSX === "undefined") throw new Error("SheetJS not loaded.");
        const wb = XLSX.read(e.target.result, { type: "binary" });
        resolve(XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]], { defval: "" }));
      } catch (err) { reject(err); }
    };
    reader.readAsBinaryString(file);
  }), []);
 
  return { parseCsv, parseXlsx };
}
 
