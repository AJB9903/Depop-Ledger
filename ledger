// ═══════════════════════════════════════════════════════════════
// DATE / FILTER HELPERS
// ═══════════════════════════════════════════════════════════════
 
function pd(str) {
  if (!str) return null;
  const [m, d, y] = str.split("/").map(Number);
  return new Date(y, m - 1, d);
}
 
function filterTxns(txns, frame) {
  if (frame === "yearly") return txns;
  const dates = txns.map(t => pd(t.saleDate)).filter(Boolean);
  if (!dates.length) return txns;
  const latest = new Date(Math.max(...dates));
  if (frame === "weekly") {
    const cut = new Date(latest); cut.setDate(cut.getDate() - 6);
    return txns.filter(t => { const d = pd(t.saleDate); return d && d >= cut; });
  }
  return txns.filter(t => { const d = pd(t.saleDate); return d && d.getMonth() === latest.getMonth() && d.getFullYear() === latest.getFullYear(); });
}
 
function sparkPoints(txns, frame) {
  if (!txns.length) return [];
  const dates = txns.map(t => pd(t.saleDate)).filter(Boolean);
  const latest = new Date(Math.max(...dates));
  const earliest = new Date(Math.min(...dates));
  if (frame === "weekly") {
    return Array.from({ length: 7 }, (_, i) => {
      const d = new Date(latest); d.setDate(d.getDate() - (6 - i));
      return txns.filter(t => { const x = pd(t.saleDate); return x && x.getDate()===d.getDate() && x.getMonth()===d.getMonth(); }).reduce((s,t)=>s+t.salePrice,0);
    });
  }
  if (frame === "monthly") {
    const days = new Date(latest.getFullYear(), latest.getMonth()+1, 0).getDate();
    return Array.from({ length: days }, (_, i) => {
      const day = i + 1;
      return txns.filter(t => { const x = pd(t.saleDate); return x && x.getDate()===day && x.getMonth()===latest.getMonth(); }).reduce((s,t)=>s+t.salePrice,0);
    });
  }
  const totalDays = Math.ceil((latest - earliest) / 86400000) + 1;
  const weeks = Math.ceil(totalDays / 7);
  return Array.from({ length: weeks }, (_, wi) => {
    const s = new Date(earliest); s.setDate(s.getDate() + wi * 7);
    const e = new Date(s);       e.setDate(e.getDate() + 6);
    return txns.filter(t => { const x = pd(t.saleDate); return x && x >= s && x <= e; }).reduce((s2,t)=>s2+t.salePrice,0);
  });
}
 
function intel(txns) {
  if (!txns.length) return null;
  const rev = txns.reduce((s,t)=>s+t.salePrice,0);
  const group = (key) => {
    const m = {};
    txns.forEach(t => {
      const k = t[key] || "Other";
      if (!m[k]) m[k] = { revenue:0, gross:0, count:0 };
      m[k].revenue += t.salePrice; m[k].gross += t.grossProfit; m[k].count++;
    });
    return Object.entries(m).map(([n,v]) => ({ name:n, ...v, roi: v.revenue>0?v.gross/v.revenue:0 }));
  };
  const brands = group("brand"), cats = group("category");
  return {
    topBrand: brands.reduce((a,b) => b.revenue>a.revenue?b:a),
    roiBrand: brands.reduce((a,b) => b.roi>a.roi?b:a),
    topCat:   cats.reduce((a,b) => b.revenue>a.revenue?b:a),
    roiCat:   cats.reduce((a,b) => b.roi>a.roi?b:a),
    totalRev: rev,
  };
}
 
